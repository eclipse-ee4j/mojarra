<!--
    Shadows the remote-container arquillian.xml bundled in the TCK util jar: this module drives a
    locally unpacked GlassFish through the managed adapter instead. glassFishHome resolves from the
    glassfish.home system property set by the failsafe plugin.
-->
<arquillian xmlns="http://jboss.org/schema/arquillian"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://jboss.org/schema/arquillian http://jboss.org/schema/arquillian/arquillian_1_0.xsd">
    <container qualifier="glassfish" default="true">
        <configuration>
            <property name="glassFishHome">${glassfish.home}</property>
            <property name="outputToConsole">true</property>
        </configuration>
    </container>
</arquillian>
