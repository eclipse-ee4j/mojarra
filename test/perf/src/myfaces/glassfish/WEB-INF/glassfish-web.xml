<!--
    Added to the WAR only by the glassfish-myfaces / payara-myfaces profiles. GlassFish/Payara ship Mojarra and
    keep it as a module (their Weld integration needs it), so the WAR uses its own bundled MyFaces instead via a
    non-delegating class loader + useBundledJsf. The profile also strips Mojarra's CDI-extension service entry from
    the container jakarta.faces.jar to avoid a WELD-001414 ambiguous requestScope clash.
-->
<glassfish-web-app error-url="">
    <class-loader delegate="false"/>
    <property name="useBundledJsf" value="true"/>
</glassfish-web-app>
