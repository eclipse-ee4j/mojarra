<!--
    Added to the WAR only by the wildfly-myfaces profile. WildFly ships Mojarra; exclude its Faces modules so the
    WAR-bundled MyFaces is used instead (paired with org.jboss.jbossfaces.WAR_BUNDLES_JSF_IMPL=true in web.xml).
-->
<jboss-deployment-structure>
    <deployment>
        <exclusions>
            <module name="org.jboss.as.jsf"/>
            <module name="jakarta.faces.api"/>
            <module name="jakarta.faces.impl"/>
        </exclusions>
    </deployment>
</jboss-deployment-structure>
